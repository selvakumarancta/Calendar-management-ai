# =============================================================================
# Calendar Agent — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Application ---
APP_ENV=development                  # development | staging | production
APP_SECRET_KEY=change-me-to-a-random-secret
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/calendar_agent.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/calendar_agent

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM Provider (multi-provider support) ---
# Supported: anthropic | openai
# Set to the provider you have an API key for
LLM_PROVIDER=anthropic

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-20250514
ANTHROPIC_MODEL_FAST=claude-haiku-3-20250414

# --- OpenAI (optional, leave blank if not using) ---
OPENAI_API_KEY=
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# --- Shared LLM Settings ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Agent ---
AGENT_MAX_ITERATIONS=10
AGENT_RECURSION_LIMIT=25
AGENT_DEFAULT_TIMEZONE=UTC
AGENT_WORKING_HOURS_START=09:00
AGENT_WORKING_HOURS_END=17:00
AGENT_BUFFER_MINUTES=15
AGENT_CACHE_TTL_SECONDS=300

# --- Email Intelligence ---
EMAIL_SCAN_INTERVAL_MINUTES=15
EMAIL_SCAN_WINDOW_HOURS=72
EMAIL_SCAN_INITIAL_HOURS=72

# --- Billing / Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# --- Monitoring ---
LANGSMITH_API_KEY=ls_...
LANGSMITH_PROJECT=calendar-agent
SENTRY_DSN=https://...@sentry.io/...

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
